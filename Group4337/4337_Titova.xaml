<Window x:Class="Group4337._4337_Titova"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Group4337"
        mc:Ignorable="d"
        Title="_4337_Titova" Height="450" Width="800">
    <Grid>
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="Информация об авторе" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

                <TextBlock Text="Имя: МАРИЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯЯ" 
                       FontSize="16" 
                       Margin="0,0,0,10"/>

                <TextBlock Text="Возраст: 18 лет" 
                       FontSize="16" 
                       Margin="0,0,0,10"/>

                <Button Content="Импорт данных" 
                    HorizontalAlignment="Center" 
                    Width="170" 
                    Background="LightPink"
                    FontSize="20"
                    Height="30"
                    Margin="0,20,0,0"
                    Click="ImportButton_Click"/>

                <Button Content="Экспорт данных" 
                     HorizontalAlignment="Center" 
                     Width="170" 
                     Background="LightGreen"
                     FontSize="20"
                     Height="30"
                     Margin="0,20,0,0"
                     Click="ExportButton_Click"/>

                <Button Content="Закрыть" 
                     HorizontalAlignment="Center" 
                     Width="150" 
                     Background="Red"
                     FontSize="25"
                     Height="60"
                     Margin="0,100,0,0"
                     Click="CloseButton_Click"/>

            </StackPanel>
        </Grid>
    </Grid>
</Window>
